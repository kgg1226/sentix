{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/session-start.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/user-prompt-reminder.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/require-ticket.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/pre-commit.js --quick 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Edit: CLAUDE.md",
      "Edit: FRAMEWORK.md",
      "Edit: .github/**",
      "Edit: .claude/settings.json",
      "Edit: .claude/agents/**",
      "Edit: scripts/hooks/**",
      "Edit: .sentix/rules/**",
      "Edit: .sentix/safety.toml",
      "Write: .claude/settings.json",
      "Write: .claude/agents/**",
      "Write: scripts/hooks/**",
      "Write: .sentix/rules/**",
      "Write: .sentix/safety.toml",
      "Bash(rm -rf *)",
      "Bash(rm -f .claude/*)",
      "Bash(rm -f scripts/hooks/*)",
      "Bash(rm -f .sentix/rules/*)",
      "Bash(rm *settings.json*)",
      "Bash(git push --force*)"
    ]
  }
}
