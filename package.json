{
  "name": "sentix",
  "version": "2.1.0",
  "description": "Autonomous multi-agent DevSecOps pipeline CLI",
  "type": "module",
  "bin": {
    "sentix": "./bin/sentix.js"
  },
  "scripts": {
    "dev": "node src/dev-server.js",
    "start": "node bin/sentix.js",
    "test": "node --test __tests__/*.test.js",
    "doctor": "node bin/sentix.js doctor"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "FRAMEWORK.md",
    ".sentix/rules/",
    ".claude/settings.json",
    ".claude/agents/",
    ".claude/rules/",
    ".claude/skills/",
    ".github/workflows/deploy.yml",
    ".github/workflows/security-scan.yml",
    "docs/",
    "scripts/update-downstream.sh",
    "scripts/pre-commit.js",
    "scripts/hooks/",
    ".claudeignore"
  ],
  "keywords": [
    "devops",
    "devsecops",
    "pipeline",
    "autonomous",
    "multi-agent",
    "claude",
    "ai"
  ],
  "author": "JANUS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kgg1226/sentix.git"
  }
}
